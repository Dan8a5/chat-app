---
import '../styles/global.css';

const nick = Astro.cookies.get('nickname')?.value;
if (nick) return Astro.redirect('/rooms');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Live Chat — Join</title>
</head>
<body class="min-h-screen bg-[#111] text-white flex flex-col items-center justify-center p-6 relative overflow-hidden">

  <!-- Background watermark -->
  <div class="absolute inset-0 flex items-center justify-start pointer-events-none select-none overflow-hidden">
    <span class="text-[18vw] font-black text-white/[0.04] leading-none tracking-tighter whitespace-nowrap">
      LIVE<br>CHAT<br>ROOM
    </span>
  </div>

  <div class="relative z-10 w-full max-w-sm">
    <!-- Label -->
    <p class="text-xs tracking-[0.2em] text-gray-500 uppercase mb-3">Real-time Communication</p>

    <!-- Title -->
    <h1 class="text-6xl font-black leading-none tracking-tight mb-1">LIVE</h1>
    <h1 class="text-6xl font-black leading-none tracking-tight mb-4">CHAT</h1>
    <div class="w-8 h-0.5 bg-[#a3e635] mb-8"></div>

    <!-- Form -->
    <form id="nickname-form">
      <label class="block text-[0.65rem] tracking-[0.15em] text-gray-400 uppercase mb-2">
        Choose a Nickname
      </label>
      <input
        id="nick-input"
        type="text"
        name="nickname"
        oninput="validateNick()"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        maxlength="20"
        placeholder="Enter nickname..."
        class="w-full bg-transparent border-0 border-b-2 border-[#a3e635] text-white text-sm px-0 py-2
               placeholder-gray-600 focus:outline-none focus:border-white transition-colors"
        required
      />
      <p id="nick-error" style="display:none"
         class="text-[0.6rem] tracking-wider text-red-400 mt-1.5"></p>

      <button
        id="submit-btn"
        type="submit"
        disabled
        class="mt-6 w-full bg-white text-black text-xs font-bold tracking-[0.2em] uppercase
               py-3 px-6 hover:bg-[#a3e635] disabled:opacity-30 disabled:cursor-not-allowed transition-colors">
        Join the Chat
      </button>
    </form>

    <p class="text-[0.6rem] tracking-[0.12em] text-gray-600 uppercase mt-4">
      No password needed. Just pick a name.
    </p>
  </div>

  <script is:inline>
    var NICK_RE = /^[a-zA-Z0-9_]{3,20}$/;
    function validateNick() {
      var val = document.getElementById('nick-input').value;
      var err = document.getElementById('nick-error');
      var btn = document.getElementById('submit-btn');
      var invalid = val.length > 0 && !NICK_RE.test(val);
      err.textContent = invalid ? 'USE 3–20 LETTERS, NUMBERS, OR UNDERSCORES' : '';
      err.style.display = invalid ? 'block' : 'none';
      btn.disabled = invalid || val.length < 3;
    }
    document.getElementById('nickname-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var nick = document.getElementById('nick-input').value.trim();
      if (!NICK_RE.test(nick)) return;
      var res = await fetch('/api/nickname', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'nickname=' + encodeURIComponent(nick),
      });
      if (res.ok || res.redirected) {
        window.location.href = '/rooms';
      }
    });
  </script>

  <!-- Footer -->
  <div class="absolute bottom-4 left-0 right-0 flex justify-center">
    <span class="text-[0.6rem] tracking-[0.25em] text-gray-700 uppercase">Live Chat Room</span>
  </div>
</body>
</html>
