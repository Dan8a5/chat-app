---
import '../../styles/global.css';

const session = Astro.cookies.get('admin_session')?.value;
if (session && session === import.meta.env.ADMIN_TOKEN) {
  return Astro.redirect('/admin/dashboard');
}

const error = Astro.url.searchParams.get('error');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — Live Chat</title>
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
  </script>
</head>
<body class="min-h-screen bg-white dark:bg-black text-black dark:text-white flex items-center justify-center">
  <div class="w-full max-w-xs mx-4">
    <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Live Chat</p>
    <h1 class="text-2xl font-black tracking-tight uppercase mb-8">Admin</h1>

    {error && (
      <p class="text-[0.65rem] tracking-[0.1em] uppercase text-red-500 mb-4">Invalid password.</p>
    )}

    <form method="POST" action="/api/admin/login">
      <label class="block text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 mb-2">
        Password
      </label>
      <input
        type="password"
        name="password"
        autofocus
        class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
               text-sm px-0 py-2 focus:outline-none focus:border-black dark:focus:border-white
               placeholder-gray-400 transition-colors mb-6"
        required
      />
      <button type="submit"
              class="w-full text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white
                     text-white dark:text-black py-3 hover:bg-[#a3e635] hover:text-black transition-colors">
        Sign In
      </button>
    </form>
  </div>
</body>
</html>
