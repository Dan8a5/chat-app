---
import '../../styles/global.css';
import { db } from '../../lib/db/index.js';
import { rooms, messages } from '../../lib/db/schema.js';
import { messageHtml, presenceHtml, loadMoreSentinelHtml } from '../../lib/html/fragments.js';
import { eq, desc } from 'drizzle-orm';

const { slug } = Astro.params;
const nick = Astro.cookies.get('nickname')?.value!;

const [room] = await db.select().from(rooms).where(eq(rooms.slug, slug!)).limit(1);
if (!room) return Astro.redirect('/rooms');

// Load initial 50 messages (desc, then reverse)
const initialRows = await db
  .select()
  .from(messages)
  .where(eq(messages.roomId, room.id))
  .orderBy(desc(messages.createdAt))
  .limit(51);

const hasMore = initialRows.length > 50;
const batch = hasMore ? initialRows.slice(0, 50) : initialRows;
const ordered = [...batch].reverse();

const initialMessagesHtml = ordered.map(messageHtml).join('');
const sentinelHtml = hasMore ? loadMoreSentinelHtml(slug!, ordered[0].id) : '';
const initialPresenceHtml = presenceHtml([]);

// All rooms for sidebar
const allRooms = await db.select().from(rooms).orderBy(rooms.createdAt);

const nickInitial = nick.charAt(0).toUpperCase();

const AVATAR_COLORS = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4','#f97316'];
function getAvatarBg(n: string): string {
  let h = 0;
  for (let i = 0; i < n.length; i++) h = (h * 31 + n.charCodeAt(i)) & 0xffff;
  return AVATAR_COLORS[h % AVATAR_COLORS.length];
}
const nickAvatarBg = getAvatarBg(nick);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{room.name.toUpperCase()} — Live Chat</title>
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
  </script>
</head>
<body class="h-screen flex bg-white dark:bg-[#0f0f0f] text-black dark:text-white overflow-hidden"
      data-slug={slug}>

  <!-- Mobile sidebar overlay -->
  <div id="sidebar-overlay" onclick="closeSidebar()"
       style="display:none"
       class="fixed inset-0 bg-black/40 z-10 sm:hidden"></div>

  <!-- ── Sidebar ─────────────────────────────────────── -->
  <aside id="sidebar"
         class="w-44 shrink-0 flex-col border-r border-gray-200 dark:border-gray-800 bg-white dark:bg-black overflow-hidden
                fixed sm:relative inset-y-0 left-0 z-20 sm:z-auto hidden sm:flex">
    <!-- Sidebar header -->
    <div class="flex items-center justify-between px-3 py-3 border-b border-gray-200 dark:border-gray-800">
      <span class="text-[0.6rem] font-black tracking-[0.2em] uppercase text-gray-500 dark:text-gray-400">Rooms</span>
      <button onclick="document.getElementById('new-room-modal').style.display='flex'"
              class="text-[0.6rem] tracking-widest uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors font-bold">
        + New
      </button>
    </div>

    <!-- Room list -->
    <nav class="flex-1 overflow-y-auto py-2">
      {allRooms.map(r => (
        <a href={`/rooms/${r.slug}`}
           onclick="closeSidebar()"
           class={`flex items-center gap-2 px-3 py-1.5 text-[0.7rem] tracking-wider uppercase transition-colors ${
             r.slug === slug
               ? 'bg-black dark:bg-white text-white dark:text-black font-bold'
               : 'text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-gray-50 dark:hover:bg-gray-900'
           }`}>
          <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${r.slug === slug ? 'bg-accent' : 'bg-gray-300 dark:bg-gray-700'}`}></span>
          {r.name}
        </a>
      ))}
    </nav>
  </aside>

  <!-- ── Main area ─────────────────────────────────── -->
  <div class="flex flex-1 flex-col overflow-hidden dark:bg-[#0f0f0f]"
       id="sse-root">

    <!-- Header -->
    <header class="shrink-0 flex items-center justify-between px-3 sm:px-5 py-2.5
                   border-b border-gray-200 dark:border-gray-800 bg-white dark:bg-black">
      <div class="flex items-center gap-3">
        <!-- Mobile hamburger -->
        <button onclick="openSidebar()"
                class="sm:hidden text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors text-base leading-none font-bold">
          ☰
        </button>
        <h1 class="text-lg font-black tracking-tight uppercase leading-none">{room.name}</h1>
      </div>
      <div class="flex items-center gap-4">
        <!-- Dark mode toggle -->
        <button id="theme-btn" onclick="toggleTheme()"
                class="text-[0.6rem] tracking-[0.15em] uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors font-bold">
          Dark
        </button>

        <!-- Sound toggle -->
        <button id="sound-btn" onclick="toggleSound()"
                class="text-[0.6rem] tracking-[0.15em] uppercase font-bold transition-colors text-gray-400 hover:text-black dark:hover:text-white">
          Sound Off
        </button>

        <!-- Online presence dropdown -->
        <div class="relative" id="presence-wrapper">
          <button onclick="togglePresenceDropdown()"
                  class="flex items-center gap-1.5 text-[0.6rem] tracking-[0.15em] uppercase font-bold text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors">
            <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
            <span id="presence-count">0</span>
            <span>Online</span>
          </button>
          <div id="presence-dropdown" style="display:none"
               class="absolute right-0 top-full mt-2 w-44 bg-white dark:bg-black border border-gray-200 dark:border-gray-800 z-30 shadow-lg">
            <div class="px-3 py-2 border-b border-gray-100 dark:border-gray-800">
              <span class="text-[0.6rem] tracking-[0.15em] uppercase text-gray-400 font-bold">
                <span id="presence-count-modal">0</span> Online
              </span>
            </div>
            <div id="presence-panel">
              <div set:html={initialPresenceHtml} />
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Messages -->
    <div id="messages-list"
         class="flex-1 overflow-y-auto py-2 flex flex-col">
      <div set:html={sentinelHtml} />
      <div set:html={initialMessagesHtml} />
    </div>

    <!-- Typing indicator -->
    <div class="px-5 py-1 min-h-5.5">
      <div id="typing-indicator">
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="shrink-0 border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-black">
      <div class="flex items-center gap-3 px-3 py-2">
        <!-- User info -->
        <div class="flex items-center gap-2 shrink-0">
          <span id="user-avatar"
                class="w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold"
                style={`background:${nickAvatarBg}`}>
            {nickInitial}
          </span>
          <span id="current-nick" class="text-[0.65rem] font-bold tracking-wider uppercase">{nick}</span>
          <button onclick="document.getElementById('rename-modal').style.display='flex'"
                  class="text-[0.55rem] tracking-[0.15em] uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors font-bold border-b border-transparent hover:border-current">
            Rename
          </button>
          <span class="text-gray-200 dark:text-gray-800">|</span>
          <button onclick="fetch('/api/signout',{method:'POST'}).then(function(){window.location.href='/'})"
                  class="text-[0.55rem] tracking-[0.15em] uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors font-bold">
            Exit
          </button>
        </div>

        <!-- Message input -->
        <div class="flex-1 flex gap-2">
            <form id="message-form" class="flex-1 flex gap-2">
            <div class="relative flex-1">
              <input id="message-input"
                     name="content"
                     autocomplete="off"
                     maxlength="2000"
                     placeholder="Type your message..."
                     class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
                            text-xs text-black dark:text-white px-0 py-1.5 focus:outline-none focus:border-black dark:focus:border-white
                            placeholder-gray-300 dark:placeholder-gray-600 transition-colors" />
              <!-- @mention dropdown -->
              <ul id="mention-dropdown" style="display:none"
                  class="absolute bottom-full left-0 mb-2 w-44 bg-white dark:bg-black border border-gray-200 dark:border-gray-800 shadow-lg z-20">
              </ul>
            </div>
            <button type="submit"
                    class="text-[0.6rem] tracking-[0.2em] uppercase font-black bg-black dark:bg-white text-white dark:text-black px-4 py-1.5 hover:bg-accent hover:text-black transition-colors">
              Send
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Profile Card Modal ───────────────────────── -->
  <div id="profile-modal" style="display:none"
       onclick="if(event.target===this)this.style.display='none'"
       class="fixed inset-0 bg-black/60 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-8 w-full max-w-sm mx-4"
         onclick="event.stopPropagation()">
      <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-4">Profile</p>
      <div class="flex items-center gap-4 mb-6">
        <span id="profile-avatar"
              class="w-12 h-12 rounded-full flex items-center justify-center text-white text-lg font-black shrink-0">
        </span>
        <div>
          <p id="profile-nick" class="text-xl font-black tracking-tight uppercase"></p>
          <p id="profile-since" class="text-[0.6rem] tracking-[0.15em] uppercase text-gray-400 mt-0.5"></p>
        </div>
      </div>
      <div class="mb-4">
        <p class="text-[0.6rem] tracking-[0.15em] uppercase text-gray-400 mb-1">Messages</p>
        <p id="profile-count" class="text-sm font-bold">0</p>
      </div>
      <div id="profile-bio-section" class="mb-6">
        <p class="text-[0.6rem] tracking-[0.15em] uppercase text-gray-400 mb-1">Bio</p>
        <p id="profile-bio" class="text-sm text-gray-600 dark:text-gray-400 italic"></p>
      </div>
      <div class="flex gap-3">
        <button type="button" onclick="document.getElementById('profile-modal').style.display='none'"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-gray-300 dark:border-gray-700 py-2.5 hover:border-black dark:hover:border-white transition-colors">
          Close
        </button>
        <button id="profile-edit-btn" type="button" style="display:none"
                onclick="openBioEdit()"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white text-white dark:text-black py-2.5 hover:bg-accent hover:text-black transition-colors">
          Edit Bio
        </button>
      </div>
    </div>
  </div>

  <!-- ── Bio Edit Modal ────────────────────────────── -->
  <div id="bio-modal" style="display:none"
       onclick="if(event.target===this)this.style.display='none'"
       class="fixed inset-0 bg-black/60 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-8 w-full max-w-sm mx-4"
         onclick="event.stopPropagation()">
      <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Profile</p>
      <h2 class="text-xl font-black tracking-tight uppercase mb-6">Edit Bio</h2>
      <form id="bio-form">
        <label class="block text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 mb-2">
          Bio <span class="text-gray-300 dark:text-gray-700 normal-case tracking-normal">(max 200 chars)</span>
        </label>
        <textarea id="bio-input" name="bio" maxlength="200" rows="3"
                  placeholder="Tell people about yourself..."
                  class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
                         text-sm px-0 py-2 focus:outline-none focus:border-black dark:focus:border-white
                         placeholder-gray-400 transition-colors resize-none"></textarea>
      </form>
      <div class="flex gap-3 mt-6">
        <button type="button" onclick="document.getElementById('bio-modal').style.display='none'"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-gray-300 dark:border-gray-700 py-2.5 hover:border-black dark:hover:border-white transition-colors">
          Cancel
        </button>
        <button type="submit" form="bio-form"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white text-white dark:text-black py-2.5 hover:bg-accent hover:text-black transition-colors">
          Save
        </button>
      </div>
    </div>
  </div>

  <!-- ── @mention toast ────────────────────────────── -->
  <div id="mention-toast" style="display:none"
       onclick="this.style.display='none'"
       class="fixed top-4 right-4 bg-black dark:bg-white text-white dark:text-black text-[0.65rem] tracking-[0.12em] uppercase font-bold px-4 py-3 z-50 shadow-lg cursor-pointer flex items-center gap-2">
    <span class="text-accent">@</span>
    <span id="mention-toast-user"></span>
  </div>

  <!-- ── New Room Modal ─────────────────────────────── -->
  <div id="new-room-modal" style="display:none"
       onclick="if(event.target===this)this.style.display='none'"
       class="fixed inset-0 bg-black/60 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-8 w-full max-w-sm mx-4"
         onclick="event.stopPropagation()">
      <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Channel</p>
      <h2 class="text-xl font-black tracking-tight uppercase mb-6">New Room</h2>
      <form id="new-room-form">
        <label class="block text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 mb-2">Room Name</label>
        <input type="text" name="name"
               placeholder="e.g. General, Random..."
               minlength="2" maxlength="50"
               class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
                      text-sm px-0 py-2 focus:outline-none focus:border-black dark:focus:border-white
                      placeholder-gray-400 transition-colors"
               required />
      </form>
      <div class="flex gap-3 mt-6">
        <button type="button" onclick="document.getElementById('new-room-modal').style.display='none'"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-gray-300 dark:border-gray-700 py-2.5 hover:border-black dark:hover:border-white transition-colors">
          Cancel
        </button>
        <button type="submit" form="new-room-form"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white text-white dark:text-black py-2.5 hover:bg-accent hover:text-black transition-colors">
          Create
        </button>
      </div>
    </div>
  </div>

  <!-- ── Rename Modal ───────────────────────────────── -->
  <div id="rename-modal" style="display:none"
       onclick="if(event.target===this)this.style.display='none'"
       class="fixed inset-0 bg-black/60 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-8 w-full max-w-sm mx-4"
         onclick="event.stopPropagation()">
      <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Profile</p>
      <h2 class="text-xl font-black tracking-tight uppercase mb-6">Change Name</h2>
      <form id="rename-form">
        <label class="block text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 mb-2">New Nickname</label>
        <input id="rename-input" type="text" name="nickname"
               placeholder="Enter new name..."
               minlength="3" maxlength="20"
               pattern="[a-zA-Z0-9_]+"
               class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
                      text-sm px-0 py-2 focus:outline-none focus:border-black dark:focus:border-white
                      placeholder-gray-400 transition-colors"
               required />
      </form>
      <div class="flex gap-3 mt-6">
        <button type="button" onclick="document.getElementById('rename-modal').style.display='none';document.getElementById('rename-input').value=''"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-gray-300 dark:border-gray-700 py-2.5 hover:border-black dark:hover:border-white transition-colors">
          Cancel
        </button>
        <button type="submit" form="rename-form"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white text-white dark:text-black py-2.5 hover:bg-accent hover:text-black transition-colors">
          Save
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ nick }}>
    window.__CHAT_NICK__ = nick;
  </script>

  <script is:inline>
    // ── Helpers ───────────────────────────────────────
    const AVATAR_COLORS = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4','#f97316'];
    function avatarBg(nick) {
      let h = 0;
      for (let i = 0; i < nick.length; i++) h = (h * 31 + nick.charCodeAt(i)) & 0xffff;
      return AVATAR_COLORS[h % AVATAR_COLORS.length];
    }

    let audioCtx = null;
    function playPing() {
      try {
        if (!audioCtx) audioCtx = new AudioContext();
        const o = audioCtx.createOscillator(), g = audioCtx.createGain();
        o.connect(g); g.connect(audioCtx.destination);
        o.frequency.value = 780;
        g.gain.setValueAtTime(0.25, audioCtx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);
        o.start(); o.stop(audioCtx.currentTime + 0.25);
      } catch(e) {}
    }

    function applyGrouping() {
      const msgs = document.querySelectorAll('#messages-list .chat-msg');
      for (let i = 1; i < msgs.length; i++) {
        const same = msgs[i-1].dataset.nick === msgs[i].dataset.nick;
        const meta = msgs[i].querySelector('.chat-meta');
        const av = msgs[i].querySelector('.chat-avatar');
        if (meta) meta.style.display = same ? 'none' : '';
        if (av) av.style.visibility = same ? 'hidden' : '';
      }
    }

    // ── Theme ─────────────────────────────────────────
    function toggleTheme() {
      const dark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', dark ? 'dark' : 'light');
      const btn = document.getElementById('theme-btn');
      if (btn) btn.textContent = dark ? 'Light' : 'Dark';
    }

    // ── Sound ─────────────────────────────────────────
    function toggleSound() {
      const on = localStorage.getItem('sound') !== 'off';
      localStorage.setItem('sound', on ? 'off' : 'on');
      const btn = document.getElementById('sound-btn');
      if (btn) { btn.textContent = on ? 'Sound Off' : 'Sound On'; btn.style.color = on ? '' : '#a3e635'; }
    }

    // ── Sidebar ───────────────────────────────────────
    function openSidebar() {
      const s = document.getElementById('sidebar');
      const o = document.getElementById('sidebar-overlay');
      if (s) { s.classList.remove('hidden'); s.classList.add('flex'); }
      if (o) o.style.display = 'block';
    }
    function closeSidebar() {
      const s = document.getElementById('sidebar');
      const o = document.getElementById('sidebar-overlay');
      if (s) { s.classList.add('hidden'); s.classList.remove('flex'); }
      if (o) o.style.display = 'none';
    }

    // ── Presence dropdown ─────────────────────────────
    function togglePresenceDropdown() {
      const dd = document.getElementById('presence-dropdown');
      if (dd) dd.style.display = dd.style.display === 'none' ? 'block' : 'none';
    }

    // ── Mention picker ────────────────────────────────
    var _presenceUsers = [];
    function insertMention(user) {
      const input = document.getElementById('message-input');
      const atPos = input.value.lastIndexOf('@');
      input.value = input.value.slice(0, atPos) + '@' + user + ' ';
      document.getElementById('mention-dropdown').style.display = 'none';
      input.focus();
    }

    // ── Global event listeners ────────────────────────
    document.addEventListener('click', function(e) {
      if (!e.target.closest('#presence-wrapper')) {
        const dd = document.getElementById('presence-dropdown');
        if (dd) dd.style.display = 'none';
      }
      if (!e.target.closest('#message-input') && !e.target.closest('#mention-dropdown')) {
        const md = document.getElementById('mention-dropdown');
        if (md) md.style.display = 'none';
      }
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        document.getElementById('new-room-modal').style.display = 'none';
        document.getElementById('rename-modal').style.display = 'none';
        document.getElementById('bio-modal').style.display = 'none';
        document.getElementById('profile-modal').style.display = 'none';
        document.getElementById('mention-dropdown').style.display = 'none';
        closeSidebar();
      }
    });

    // ── Profile card ──────────────────────────────────
    var _currentProfileNick = null;
    async function openProfile(nick) {
      _currentProfileNick = nick;
      const AVATAR_COLORS = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4','#f97316'];
      function avatarBgLocal(n) {
        let h = 0;
        for (let i = 0; i < n.length; i++) h = (h * 31 + n.charCodeAt(i)) & 0xffff;
        return AVATAR_COLORS[h % AVATAR_COLORS.length];
      }
      const av = document.getElementById('profile-avatar');
      const nickEl = document.getElementById('profile-nick');
      const sinceEl = document.getElementById('profile-since');
      const countEl = document.getElementById('profile-count');
      const bioEl = document.getElementById('profile-bio');
      const editBtn = document.getElementById('profile-edit-btn');
      if (av) { av.textContent = nick.charAt(0).toUpperCase(); av.style.background = avatarBgLocal(nick); }
      if (nickEl) nickEl.textContent = nick.toUpperCase();
      if (sinceEl) sinceEl.textContent = '';
      if (countEl) countEl.textContent = '—';
      if (bioEl) bioEl.textContent = '';
      if (editBtn) editBtn.style.display = 'none';
      document.getElementById('profile-modal').style.display = 'flex';
      try {
        const res = await fetch('/api/profile/' + encodeURIComponent(nick));
        const data = await res.json();
        if (data) {
          if (sinceEl) sinceEl.textContent = 'Joined ' + new Date(data.createdAt).toLocaleDateString([], { year: 'numeric', month: 'short', day: 'numeric' });
          if (countEl) countEl.textContent = data.messageCount.toLocaleString();
          if (bioEl) bioEl.textContent = data.bio || '';
        }
        const NICK = window.__CHAT_NICK__ || '';
        if (editBtn && nick === NICK) editBtn.style.display = '';
      } catch(e) {}
    }

    document.addEventListener('click', function(e) {
      var target = e.target.closest('[data-profile-nick]');
      if (target) {
        e.stopPropagation();
        openProfile(target.dataset.profileNick);
      }
    });

    function openBioEdit() {
      document.getElementById('profile-modal').style.display = 'none';
      const bioInput = document.getElementById('bio-input');
      const bioEl = document.getElementById('profile-bio');
      if (bioInput && bioEl) bioInput.value = bioEl.textContent;
      document.getElementById('bio-modal').style.display = 'flex';
    }

    // ── Boot ──────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function() {
      const slug = document.body.dataset.slug;
      const NICK = window.__CHAT_NICK__ || '';

      // Init labels
      const dark = localStorage.getItem('theme') === 'dark';
      const themeBtn = document.getElementById('theme-btn');
      if (themeBtn) themeBtn.textContent = dark ? 'Light' : 'Dark';
      const soundOn = localStorage.getItem('sound') !== 'off';
      const soundBtn = document.getElementById('sound-btn');
      if (soundBtn) { soundBtn.textContent = soundOn ? 'Sound On' : 'Sound Off'; if (soundOn) soundBtn.style.color = '#a3e635'; }

      // ── SSE ───────────────────────────────────────────
      const evtSource = new EventSource('/api/rooms/' + slug + '/sse');

      evtSource.addEventListener('message', function(e) {
        const list = document.getElementById('messages-list');
        if (!list) return;
        const tpl = document.createElement('template');
        tpl.innerHTML = e.data;
        list.append(...tpl.content.childNodes);
        list.scrollTop = list.scrollHeight;
        applyGrouping();
        if (localStorage.getItem('sound') !== 'off') playPing();
        // Mention toast
        if (NICK && e.data.includes('@' + NICK)) {
          const m = e.data.match(/chat-nick[^>]*>([^<]+)</);
          const sender = m ? m[1] : '?';
          const toast = document.getElementById('mention-toast');
          const toastUser = document.getElementById('mention-toast-user');
          if (toast && toastUser) {
            toastUser.textContent = sender + ' MENTIONED YOU';
            toast.style.display = 'flex';
            setTimeout(function() { toast.style.display = 'none'; }, 4000);
          }
        }
      });

      evtSource.addEventListener('presence', function(e) {
        const panel = document.getElementById('presence-panel');
        if (!panel) return;
        panel.innerHTML = e.data;
        const count = panel.querySelectorAll('.pres-item').length;
        const c1 = document.getElementById('presence-count');
        const c2 = document.getElementById('presence-count-modal');
        if (c1) c1.textContent = count;
        if (c2) c2.textContent = count;
        _presenceUsers = Array.from(panel.querySelectorAll('.pres-nick')).map(function(el) { return el.textContent.trim(); }).filter(Boolean);
      });

      evtSource.addEventListener('typing', function(e) {
        const el = document.getElementById('typing-indicator');
        if (el) el.innerHTML = e.data;
      });

      evtSource.addEventListener('kicked', function(e) {
        if (e.data.trim() === NICK) {
          evtSource.close();
          window.location.href = '/';
        }
      });

      // ── New room form ─────────────────────────────────
      const newRoomForm = document.getElementById('new-room-form');
      newRoomForm && newRoomForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        var name = this.querySelector('input[name="name"]').value.trim();
        if (!name) return;
        var res = await fetch('/api/rooms', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'name=' + encodeURIComponent(name),
        });
        window.location.href = res.url;
      });

      // ── Message form ──────────────────────────────────
      const form = document.getElementById('message-form');
      const input = document.getElementById('message-input');

      form && form.addEventListener('submit', async function(e) {
        e.preventDefault();
        const content = input.value.trim();
        if (!content) return;
        input.value = '';
        await fetch('/api/rooms/' + slug + '/messages', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'content=' + encodeURIComponent(content),
        });
      });

      // ── Typing + mention picker ───────────────────────
      let typingTimer;
      input && input.addEventListener('input', function(e) {
        const val = e.target.value;
        const atPos = val.lastIndexOf('@');
        if (atPos !== -1 && (atPos === 0 || val[atPos-1] === ' ')) {
          const query = val.slice(atPos + 1).toLowerCase();
          const matches = _presenceUsers.filter(function(u) { return u.toLowerCase().startsWith(query); });
          const dd = document.getElementById('mention-dropdown');
          if (matches.length && dd) {
            dd.innerHTML = '';
            matches.forEach(function(u) {
              var li = document.createElement('li');
              li.textContent = '@' + u;
              li.className = 'px-3 py-1.5 text-[0.7rem] tracking-wider uppercase cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-900 text-gray-700 dark:text-gray-300';
              li.addEventListener('click', function() { insertMention(u); });
              dd.appendChild(li);
            });
            dd.style.display = 'block';
          } else if (dd) { dd.style.display = 'none'; }
        } else {
          const dd = document.getElementById('mention-dropdown');
          if (dd) dd.style.display = 'none';
        }
      });

      input && input.addEventListener('keyup', function(e) {
        if (e.key === 'Enter') return;
        clearTimeout(typingTimer);
        typingTimer = setTimeout(function() {
          fetch('/api/rooms/' + slug + '/typing', { method: 'POST' });
        }, 500);
      });

      // ── Rename form ───────────────────────────────────
      const renameForm = document.getElementById('rename-form');
      renameForm && renameForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const newNick = (document.getElementById('rename-input')?.value ?? '').trim();
        if (!newNick) return;
        const res = await fetch('/api/nickname/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'nickname=' + encodeURIComponent(newNick),
        });
        if (res.ok) {
          document.getElementById('current-nick').textContent = newNick.toUpperCase();
          const avatar = document.getElementById('user-avatar');
          if (avatar) { avatar.textContent = newNick.charAt(0).toUpperCase(); avatar.style.background = avatarBg(newNick); }
          document.getElementById('rename-modal').style.display = 'none';
          document.getElementById('rename-input').value = '';
        }
      });

      // ── Bio form ──────────────────────────────────────
      const bioForm = document.getElementById('bio-form');
      bioForm && bioForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const bio = (document.getElementById('bio-input')?.value ?? '').trim();
        await fetch('/api/profile', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'bio=' + encodeURIComponent(bio),
        });
        const bioEl = document.getElementById('profile-bio');
        if (bioEl) bioEl.textContent = bio;
        document.getElementById('bio-modal').style.display = 'none';
      });

      // ── Load more ─────────────────────────────────────
      function attachLoadMore() {
        const sentinel = document.getElementById('load-more-sentinel');
        if (!sentinel) return;
        const obs = new IntersectionObserver(async function([entry]) {
          if (!entry.isIntersecting) return;
          obs.disconnect();
          const res = await fetch('/api/rooms/' + slug + '/messages?before=' + sentinel.dataset.before);
          const html = await res.text();
          const tpl = document.createElement('template');
          tpl.innerHTML = html;
          sentinel.replaceWith(...tpl.content.childNodes);
          applyGrouping();
          attachLoadMore();
        });
        obs.observe(sentinel);
      }
      attachLoadMore();
      applyGrouping();
    });
  </script>
</body>
</html>
