---
import '../../styles/global.css';
import { db } from '../../lib/db/index.js';
import { rooms, messages } from '../../lib/db/schema.js';
import { eq, count } from 'drizzle-orm';

const nick = Astro.cookies.get('nickname')?.value!;

const allRooms = await db
  .select({
    id: rooms.id,
    name: rooms.name,
    slug: rooms.slug,
    createdAt: rooms.createdAt,
    messageCount: count(messages.id),
  })
  .from(rooms)
  .leftJoin(messages, eq(messages.roomId, rooms.id))
  .groupBy(rooms.id)
  .orderBy(rooms.createdAt);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ChatApp — Rooms</title>
  <script src="/alpine.min.js" defer is:inline></script>
  <script src="/htmx.min.js" defer is:inline></script>
</head>
<body class="min-h-screen bg-gray-50 dark:bg-gray-900">
  <!-- Header -->
  <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-2xl">💬</span>
      <span class="text-xl font-bold text-gray-900 dark:text-white">ChatApp</span>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-sm text-gray-500 dark:text-gray-400">Signed in as <strong class="text-gray-900 dark:text-white">{nick}</strong></span>
      <a href="/api/signout" class="text-xs text-indigo-600 hover:underline">Sign out</a>
    </div>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-8" x-data="createRoomModal()">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Rooms</h1>
      <button @click="open = true"
              class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg px-4 py-2 transition">
        + New Room
      </button>
    </div>

    <!-- Room list -->
    <div class="space-y-3">
      {allRooms.map(room => (
        <div class="flex items-center gap-2">
          <a href={`/rooms/${room.slug}`}
             class="flex-1 flex items-center justify-between bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 px-5 py-4 hover:border-indigo-400 hover:shadow-sm transition group">
            <div>
              <div class="font-semibold text-gray-900 dark:text-white group-hover:text-indigo-600">
                # {room.name}
              </div>
              <div class="text-xs text-gray-400 mt-0.5">{room.messageCount} messages</div>
            </div>
            <span class="text-sm text-indigo-600 font-medium">Enter →</span>
          </a>
          <button
            hx-delete={`/api/rooms/${room.slug}`}
            hx-confirm={`Delete "${room.name}" and all its messages?`}
            hx-swap="none"
            hx-on::after-request="if(event.detail.successful) window.location.href='/rooms'"
            class="p-2 text-gray-400 hover:text-red-500 transition rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20"
            title="Delete room">
            ✕
          </button>
        </div>
      ))}

      {allRooms.length === 0 && (
        <p class="text-center text-gray-400 py-12">No rooms yet. Create one!</p>
      )}
    </div>

    <!-- Create Room Modal -->
    <div x-show="open" x-cloak
         class="fixed inset-0 bg-black/50 flex items-center justify-center z-50"
         @keydown.escape.window="open = false">
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-8 w-full max-w-md mx-4"
           @click.stop>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Create a Room</h2>
        <form id="create-room-form"
              hx-post="/api/rooms"
              hx-swap="none"
              hx-on::after-request="handleResponse(event)">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Room name</label>
          <input type="text" name="name"
                 x-model="roomName"
                 placeholder="e.g. general"
                 minlength="2" maxlength="50"
                 class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700
                        text-gray-900 dark:text-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500"
                 required />
        </form>
        <div class="flex gap-3 mt-4">
          <button type="button" @click="open = false"
                  class="flex-1 border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 text-sm text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
            Cancel
          </button>
          <button type="submit" form="create-room-form"
                  class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg px-4 py-2 text-sm font-semibold transition">
            Create
          </button>
        </div>
      </div>
    </div>
  </main>

  <script is:inline>
    function createRoomModal() {
      return {
        open: false,
        roomName: '',
        handleResponse(event) {
          const xhr = event.detail?.xhr;
          if (xhr) {
            const redirect = xhr.getResponseHeader('HX-Redirect');
            if (redirect) window.location.href = redirect;
          }
        },
      };
    }
  </script>
</body>
</html>
