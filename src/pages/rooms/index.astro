---
import '../../styles/global.css';
import { db } from '../../lib/db/index.js';
import { rooms, messages } from '../../lib/db/schema.js';
import { eq, count } from 'drizzle-orm';

const nick = Astro.cookies.get('nickname')?.value!;

const allRooms = await db
  .select({
    id: rooms.id,
    name: rooms.name,
    slug: rooms.slug,
    createdAt: rooms.createdAt,
    messageCount: count(messages.id),
  })
  .from(rooms)
  .leftJoin(messages, eq(messages.roomId, rooms.id))
  .groupBy(rooms.id)
  .orderBy(rooms.createdAt);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Live Chat — Rooms</title>
</head>
<body class="min-h-screen bg-white dark:bg-black text-black dark:text-white">

  <!-- Header -->
  <header class="border-b border-gray-200 dark:border-gray-800 px-6 py-3 flex items-center justify-between">
    <span class="text-xs font-bold tracking-[0.2em] uppercase">Live Chat</span>
    <div class="flex items-center gap-4">
      <span class="text-xs tracking-wider text-gray-400 uppercase">{nick}</span>
      <button id="theme-btn" onclick="toggleTheme()"
              class="text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors">
        Dark
      </button>
      <button onclick="fetch('/api/signout',{method:'POST'}).then(function(){window.location.href='/'})"
              class="text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 hover:text-black dark:hover:text-white transition-colors">
        Sign out
      </button>
    </div>
  </header>

  <main class="max-w-xl mx-auto px-6 py-10">
    <!-- Page title -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Channels</p>
        <h1 class="text-2xl font-black tracking-tight uppercase">Rooms</h1>
      </div>
      <button onclick="document.getElementById('new-room-modal').style.display='flex'"
              class="text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-black dark:border-white
                     px-4 py-2 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors">
        + New
      </button>
    </div>

    <!-- Room list -->
    <div class="space-y-1">
      {allRooms.map(room => (
        <div class="flex items-center gap-2 group">
          <a href={`/rooms/${room.slug}`}
             class="flex-1 flex items-center justify-between border border-gray-200 dark:border-gray-800
                    px-4 py-3 hover:border-black dark:hover:border-white transition-colors">
            <div class="flex items-center gap-3">
              <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0"></span>
              <span class="text-xs font-bold tracking-[0.1em] uppercase">{room.name}</span>
            </div>
            <div class="flex items-center gap-4">
              <span class="text-[0.6rem] tracking-wider text-gray-400 uppercase">
                {room.messageCount} msg
              </span>
              <span class="text-[0.65rem] tracking-wider text-gray-400 group-hover:text-black dark:group-hover:text-white transition-colors uppercase">
                Enter &rarr;
              </span>
            </div>
          </a>
          <button
            hx-delete={`/api/rooms/${room.slug}`}
            hx-confirm={`Delete "${room.name}" and all its messages?`}
            hx-swap="none"
            hx-on::after-request="if(event.detail.successful) window.location.href='/rooms'"
            class="p-2 text-gray-300 dark:text-gray-700 hover:text-red-500 dark:hover:text-red-400 transition-colors"
            title="Delete room">
            ✕
          </button>
        </div>
      ))}

      {allRooms.length === 0 && (
        <p class="text-[0.7rem] tracking-[0.1em] text-gray-400 uppercase py-12 text-center">
          No rooms yet. Create one!
        </p>
      )}
    </div>
  </main>

  <!-- New Room Modal -->
  <div id="new-room-modal" style="display:none"
       onclick="if(event.target===this)this.style.display='none'"
       class="fixed inset-0 bg-black/60 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-800 p-8 w-full max-w-sm mx-4"
         onclick="event.stopPropagation()">
      <p class="text-[0.6rem] tracking-[0.2em] text-gray-400 uppercase mb-1">Channel</p>
      <h2 class="text-xl font-black tracking-tight uppercase mb-6">New Room</h2>

      <form id="create-room-form">
        <label class="block text-[0.65rem] tracking-[0.15em] uppercase text-gray-400 mb-2">
          Room Name
        </label>
        <input type="text" name="name"
               placeholder="e.g. General, Random..."
               minlength="2" maxlength="50"
               class="w-full bg-transparent border-0 border-b border-gray-300 dark:border-gray-700
                      text-sm px-0 py-2 focus:outline-none focus:border-black dark:focus:border-white
                      placeholder-gray-400 transition-colors"
               required />
      </form>

      <div class="flex gap-3 mt-6">
        <button type="button" onclick="document.getElementById('new-room-modal').style.display='none'"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold border border-gray-300 dark:border-gray-700
                       py-2.5 hover:border-black dark:hover:border-white transition-colors">
          Cancel
        </button>
        <button type="submit" form="create-room-form"
                class="flex-1 text-[0.65rem] tracking-[0.15em] uppercase font-bold bg-black dark:bg-white
                       text-white dark:text-black py-2.5 hover:bg-[#a3e635] hover:text-black transition-colors">
          Create
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      document.getElementById('theme-btn').textContent = isDark ? 'Light' : 'Dark';
    }
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.classList.add('dark');
      document.getElementById('theme-btn').textContent = 'Light';
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') document.getElementById('new-room-modal').style.display = 'none';
    });
    document.getElementById('create-room-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      var name = this.querySelector('input[name="name"]').value.trim();
      if (!name) return;
      var res = await fetch('/api/rooms', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'name=' + encodeURIComponent(name),
      });
      window.location.href = res.url;
    });
  </script>
</body>
</html>
